---
import BaseLayout from '../layouts/BaseLayout.astro';
import body from '../fragments/home.html?raw';
---
<BaseLayout>
  <main set:html={body}></main>
</BaseLayout>

<script>
  import { gsap, splitWords, magnetic, revealOnScroll, parallax, reducedMotion } from '../scripts/motion';
  import { initNeural } from '../scripts/neural';

  function initHero() {
    const hero = document.querySelector<HTMLElement>('.hero');
    if (!hero || hero.dataset.anim) return;
    hero.dataset.anim = '1';

    const canvas = hero.querySelector<HTMLCanvasElement>('canvas[data-neural]');
    if (canvas) initNeural(canvas);

    const line = hero.querySelector<HTMLElement>('.hero-line[data-split]');
    const words = line ? splitWords(line) : [];
    const rest = Array.from(
      hero.querySelectorAll<HTMLElement>('[data-hero-in]'),
    );
    magnetic(hero);

    if (reducedMotion) {
      gsap.set([...words, ...rest], { opacity: 1, y: 0 });
      return;
    }

    const tl = gsap.timeline({ defaults: { ease: 'power3.out', duration: 0.7 } });
    tl.to(hero.querySelector('.hero-badge'), { autoAlpha: 1, y: 0 })
      .to(words, { autoAlpha: 1, y: 0, stagger: 0.05 }, '-=0.4')
      .to(hero.querySelector('.hero-title-accent'), { autoAlpha: 1, y: 0 }, '-=0.5')
      .to(hero.querySelector('.hero-sub'), { autoAlpha: 1, y: 0 }, '-=0.45')
      .to(hero.querySelector('.hero-actions'), { autoAlpha: 1, y: 0 }, '-=0.5')
      .to(hero.querySelector('.hero-stats'), { autoAlpha: 1, y: 0 }, '-=0.5');
  }

  function initJourney() {
    const section = document.querySelector<HTMLElement>('.journey');
    const track = section?.querySelector<HTMLElement>('.journey-track');
    if (!section || !track || section.dataset.anim) return;
    section.dataset.anim = '1';

    const line = track.querySelector<HTMLElement>('[data-journey-line]');
    const steps = Array.from(track.querySelectorAll<HTMLElement>('.journey-step'));

    // Steps are visible via CSS when motion isn't ready (reduced-motion).
    if (reducedMotion) return;

    // Reserve steps so the page-wide reveal skips them (timeline drives them).
    steps.forEach((s) => (s.dataset.mDone = '1'));

    gsap
      .timeline({ scrollTrigger: { trigger: track, start: 'top 78%', once: true } })
      .to(line, { scaleX: 1, duration: 0.6, ease: 'power2.out' })
      .to(
        steps,
        { autoAlpha: 1, y: 0, duration: 0.5, ease: 'back.out(1.6)', stagger: 0.12 },
        '-=0.3',
      );
  }

  function initHome() {
    initHero();
    initJourney(); // reserves journey steps before the page-wide reveal runs
    revealOnScroll(document); // section headers etc. (skips reserved elements)
    parallax(document); // bundle-banner glow depth
  }

  document.addEventListener('astro:page-load', initHome);
</script>
