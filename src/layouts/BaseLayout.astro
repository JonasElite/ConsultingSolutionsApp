---
import { ViewTransitions } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
// Self-hosted variable fonts (no external requests, no render-blocking).
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import '../styles/theme-v2.css';
import '../styles/motion.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'KI-Transformation | Beratungsportfolio',
  description = 'Ihr Partner für KI-Transformation im Mittelstand. Modulares Beratungsportfolio von der Strategie bis zur Verankerung.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />
    <meta name="theme-color" content="#00338d" />

    <!-- Soft cross-document transitions between routes -->
    <ViewTransitions />

    <!-- Applied before first paint: theme + motion-ready (prevents flashes) -->
    <script is:inline>
      (() => {
        const html = document.documentElement;
        try {
          const stored = localStorage.getItem('theme');
          html.setAttribute(
            'data-theme',
            stored || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'),
          );
        } catch (e) {
          html.setAttribute('data-theme', 'light');
        }
        try {
          if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
            html.classList.add('motion-ready');
            // Safety net: if the motion engine never boots, reveal everything.
            setTimeout(() => {
              if (!html.classList.contains('motion-booted')) html.classList.remove('motion-ready');
            }, 2500);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Zum Inhalt springen</a>
    <div class="scroll-progress" id="scrollProgress" aria-hidden="true"></div>
    <Nav />
    <slot />
    <Footer />

    <script>
      // Site-wide: UI + smooth scroll only (no GSAP — that loads per animated page).
      import '../scripts/ui.ts';
      import { initSmoothScroll, scrollTop } from '../scripts/smoothscroll';

      initSmoothScroll();
      document.addEventListener('astro:after-swap', scrollTop);
    </script>
  </body>
</html>
