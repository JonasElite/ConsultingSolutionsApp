---
const base = import.meta.env.BASE_URL;
const strip = (p: string) => p.replace(/\/+$/, '') || '/';
const withBase = (r: string) => {
  const b = base.replace(/\/$/, '');
  return (b + (r === '/' ? '/' : '/' + r.replace(/^\//, ''))) || '/';
};
const current = strip(Astro.url.pathname);

const links = [
  { label: 'Übersicht', route: '/' },
  { label: 'Modul 1', route: '/modul-1' },
  { label: 'Modul 2', route: '/modul-2' },
  { label: 'Modul 3', route: '/modul-3' },
  { label: 'Modul 4', route: '/modul-4' },
  { label: 'Team', route: '/team' },
];

const mobileLinks = [
  { label: 'Übersicht', route: '/' },
  { label: 'Modul 1 – KI-Mehrwert', route: '/modul-1' },
  { label: 'Modul 2 – KI-Kultur', route: '/modul-2' },
  { label: 'Modul 3 – KI-Governance', route: '/modul-3' },
  { label: 'Modul 4 – Organisationsmodell', route: '/modul-4' },
  { label: 'Team', route: '/team' },
  { label: 'Kontakt', route: '/kontakt' },
];

const isActive = (route: string) => current === strip(withBase(route));
---

<nav class="nav" id="mainNav">
  <div class="nav-inner">
    <a href={withBase('/')} class="nav-logo">
      <svg width="40" height="32" viewBox="0 0 40 32" fill="none" aria-label="KI Beratung Logo">
        <rect width="40" height="32" rx="2" fill="#0091da" />
        <text x="20" y="22" text-anchor="middle" fill="white" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="15" letter-spacing="0.5">KI</text>
      </svg>
      <span class="nav-brand">KI<span class="nav-brand-accent">Beratung</span></span>
    </a>

    <div class="nav-links">
      {links.map((l) => (
        <a
          class:list={['nav-link', { active: isActive(l.route) }]}
          href={withBase(l.route)}
          aria-current={isActive(l.route) ? 'page' : undefined}
        >{l.label}</a>
      ))}
      <a class="nav-link nav-cta" href={withBase('/kontakt')}>Kontakt</a>
    </div>

    <div class="nav-right">
      <button class="theme-toggle" data-theme-toggle aria-label="Farbschema umschalten">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <button class="nav-hamburger" id="navHamburger" aria-label="Menü öffnen" aria-controls="navMobile" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="nav-mobile" id="navMobile">
    {mobileLinks.map((l) => (
      <a class="nav-link" href={withBase(l.route)}>{l.label}</a>
    ))}
  </div>
</nav>
